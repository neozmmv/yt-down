{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "YouTube Media Downloader",
  "version": "0.1.0",
  "identifier": "YouTube-Media-Downloader",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "YouTube Media Downloader",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "resources": [
    "bin/yt-dlp.exe",
    "bin/ffmpeg.exe",
    "bin/ffprobe.exe"
  ],
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
